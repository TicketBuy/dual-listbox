{
    "name": "dual-listbox",
    "version": "2.0.0",
    "description": "Dual listbox for multi-select elements",
    "main": "./dist/dual-listbox.cjs",
    "module": "./dist/dual-listbox.mjs",
    "exports": {
        ".": {
            "import": "./dist/dual-listbox.mjs",
            "require": "./dist/dual-listbox.cjs"
        },
        "./dist/dual-listbox.css": "./dist/dual-listbox.css"
    },
    "files": ["dist"],
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.2",
        "jsdom": "^29.0.1",
        "prettier": "^3.8.1",
        "sass": "^1.87.0",
        "serve": "^14.0.1",
        "vite": "^8.0.3",
        "vitest": "^4.1.2"
    },
    "scripts": {
        "test": "vitest run --coverage",
        "build": "vite build",
        "serve": "serve",
        "watch": "vite build --watch",
        "lint": "prettier src/ -c",
        "format": "prettier src/ -w",
        "prepare-release": "npm run format && npm test && npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/maykinmedia/dual-listbox.git"
    },
    "keywords": [
        "Select",
        "Dual",
        "Listbox",
        "Multiselect",
        "Multi"
    ],
    "author": "Maykin Media <info@maykinmedia.nl>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/maykinmedia/dual-listbox/issues"
    },
    "homepage": "https://github.com/maykinmedia/dual-listbox#readme"
}
